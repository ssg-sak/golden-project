# 환경 변수 (Git 업로드 금지)
.env
.env.*
!.env.example

# 로컬 의존성/빌드 산출물
node_modules/
dist/
**/.vite/
coverage/

# Python 캐시 및 가상환경
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# 로컬 실행 산출물 및 임시 파일
*.log
*.tmp
*.temp
result.txt

.DS_Store
*.log
test-results/
playwright-report/

