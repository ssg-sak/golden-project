# 카카오맵 JavaScript 키 — https://developers.kakao.com
# 플랫폼에 http://localhost:5173 등록
VITE_KAKAO_MAP_APP_KEY=

# 카카오 모빌리티 REST API 키 (백엔드용)
KAKAO_REST_API_KEY=

# 공공데이터포털 — 국립중앙의료원 응급의료기관 정보 조회 API
# https://www.data.go.kr/data/15000563/openapi.do
# 승인 후 마이페이지에서 키 복사 (디코딩 키 또는 URL 인코딩 키)
DATA_GO_KR_API_KEY=

# 실시간 병상 API
# - 승인 대기: true (Mock 병상)
# - 승인 완료: false + 위 DATA_GO_KR_API_KEY 설정 후 백엔드 재시작
USE_MOCK_API=true

# 연결 확인: python tests/integration/verify_realtime_api.py

# 실 API 모드: 백그라운드 병상 캐시 폴링 주기(초). 60~300, 기본 120
# BED_CACHE_POLL_INTERVAL_SEC=120

# FastAPI 백엔드 (병원 API)
VITE_API_BASE_URL=http://localhost:8000

# ==========================================
# Dynamic Dashboard & Automated Scheduler
# ==========================================
# 기존 정적 대시보드(false) vs 동적 대시보드(true)
VITE_USE_DYNAMIC_DASHBOARD_DATA=false

# 공공데이터 수집 스케줄러. 데이터 무결성 검증과 운영 로그 확인 전에는 false 유지.
# 수집 성공이 정책 공개본 자동 승격을 의미하지 않음.
ENABLE_PUBLIC_DATA_SCHEDULER=false

# SGIS (행정구역 경계)
SGIS_CONSUMER_KEY=
SGIS_CONSUMER_SECRET=

# 수동 데이터 갱신을 위한 관리자 토큰. 비어 있으면 갱신 API는 503으로 비활성화됨.
DATA_REFRESH_ADMIN_TOKEN=

# (선택) 행정안전부 인구 API base URL — 미설정 시 공공데이터 표준 경로 사용
# POPULATION_API_BASE_URL=https://apis.data.go.kr/1741000/AdmDongPopulation/AdmDongPopulation
# POPULATION_API_OPERATION=getAdmDongPopulation

# 기준 시간대
APP_TIMEZONE=Asia/Seoul
